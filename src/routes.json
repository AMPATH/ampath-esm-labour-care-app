{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=1.2",
    "webservices.rest": ">=2.2.0"
  },
  "extensions": [
    {
      "name": "labour-care-summary-dashboard",
      "slot": "patient-chart-dashboard-slot",
      "component": "patientChartLabourCareLink",
      "meta": {
        "slot": "patient-chart-labour-care-dashboard-slot",
        "path": "Labour Care",
        "layoutMode": "anchored"
      },
      "order": 17,
      "online": true,
      "offline": true
    },
    {
      "name": "labour-care-details-overview",
      "slot": "patient-chart-labour-care-dashboard-slot",
      "component": "root",
      "online": true,
      "offline": true
    },
    {
      "name": "blood-pressure-chart",
      "slot": "labour-care-chart-slot",
      "component": "bloodPressureChart",
      "order": 5,
      "online": true,
      "offline": true
    }
  ],
  "pages": [],
  "workspaces2": [
    {
      "name": "foetal-heart-rate-workspace",
      "component": "foetalHeartRateForm",
      "window": "labour-care-window"
    },
    {
      "name": "cervical-workspace",
      "component": "cervicalForm",
      "window": "labour-care-window"
    },
    {
      "name": "blood-pressure-workspace",
      "component": "bloodPressureForm",
      "window": "labour-care-window"
    },
    {
      "name": "drugs-and-fluids-workspace",
      "component": "drugsAndFluidsForm",
      "window": "labour-care-window"
    },
    {
      "name": "membrane-amniotic-fluid-and-moulding-workspace",
      "component": "membraneAmnioticFluidAndMouldingForm",
      "window": "labour-care-window"
    },
    {
      "name": "oxytocin-workspace",
      "component": "oxytocinForm",
      "window": "labour-care-window"
    },
    {
      "name": "temperature-workspace",
      "component": "temperatureForm",
      "window": "labour-care-window"
    },
    {
      "name": "urine-workspace",
      "component": "urineForm",
      "window": "labour-care-window"
    }
  ],
  "workspaceWindows2": [
    {
      "name": "labour-care-window",
      "group": "labour-care-group"
    }
  ],
  "workspaceGroups2": [
    {
      "name": "labour-care-group",
      "overlay": true
    }
  ]
}